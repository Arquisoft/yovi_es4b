{
  "openapi": "3.1.0",
  "info": {
    "title": "Yovi External Bot API",
    "version": "1.0.0",
    "description": "Public API exposed by the gateway for external clients and tournament bots. It centralizes user access, game management and bot-vs-position move selection without exposing internal service topology."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Operational endpoints."
    },
    {
      "name": "Bots",
      "description": "Bot catalogue and move selection."
    },
    {
      "name": "Users",
      "description": "External user-facing operations exposed through the gateway."
    },
    {
      "name": "Games",
      "description": "Game lifecycle management through the gateway."
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Coordinates": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "z"
        ],
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "z": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "YENPosition": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "size",
          "turn",
          "players",
          "layout"
        ],
        "properties": {
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Board size."
          },
          "turn": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Turn encoded in YEN. The engine derives the effective turn from the board layout if needed."
          },
          "players": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string",
              "enum": [
                "B",
                "R"
              ]
            },
            "description": "YEN player symbols. This API expects the standard GameY encoding ['B', 'R']."
          },
          "layout": {
            "type": "string",
            "description": "Board encoded row by row with '/' separators and '.' for empty cells."
          }
        },
        "example": {
          "size": 3,
          "turn": 0,
          "players": [
            "B",
            "R"
          ],
          "layout": "./../..."
        }
      },
      "GameMode": {
        "type": "string",
        "enum": [
          "human_vs_human",
          "human_vs_bot"
        ]
      },
      "CreateGameRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "size": {
            "type": "integer",
            "minimum": 1,
            "default": 7
          },
          "mode": {
            "$ref": "#/components/schemas/GameMode"
          },
          "bot_id": {
            "type": "string",
            "description": "Bot identifier used when mode is human_vs_bot."
          },
          "opponent_user_id": {
            "type": "string",
            "description": "Optional user identifier for the second player in human_vs_human games."
          }
        },
        "example": {
          "size": 7,
          "mode": "human_vs_bot",
          "bot_id": "greedy_bot"
        }
      },
      "MoveRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "coords"
        ],
        "properties": {
          "coords": {
            "$ref": "#/components/schemas/Coordinates"
          }
        }
      },
      "GameStateResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "api_version",
          "game_id",
          "mode",
          "bot_id",
          "yen",
          "game_over",
          "next_player",
          "winner"
        ],
        "properties": {
          "api_version": {
            "type": "string",
            "example": "v1"
          },
          "game_id": {
            "type": "string"
          },
          "mode": {
            "$ref": "#/components/schemas/GameMode"
          },
          "bot_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "yen": {
            "$ref": "#/components/schemas/YENPosition"
          },
          "game_over": {
            "type": "boolean"
          },
          "next_player": {
            "type": [
              "integer",
              "null"
            ]
          },
          "winner": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "CredentialsRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "username",
          "token",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "PlayerStats": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "userId",
          "totalGames",
          "victories",
          "defeats",
          "updatedAt"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "totalGames": {
            "type": "integer",
            "minimum": 0
          },
          "victories": {
            "type": "integer",
            "minimum": 0
          },
          "defeats": {
            "type": "integer",
            "minimum": 0
          },
          "updatedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "username",
          "stats"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "stats": {
            "$ref": "#/components/schemas/PlayerStats"
          }
        }
      },
      "MatchHistoryItem": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "gameId",
          "userId",
          "result",
          "endedAt"
        ],
        "properties": {
          "gameId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "win",
              "loss"
            ]
          },
          "endedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MatchHistoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "userId",
          "count",
          "items"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchHistoryItem"
            }
          }
        }
      },
      "BotDescriptor": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bot_id",
          "strategy",
          "description"
        ],
        "properties": {
          "bot_id": {
            "type": "string"
          },
          "strategy": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "BotCatalogResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "default_bot_id",
          "items"
        ],
        "properties": {
          "default_bot_id": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BotDescriptor"
            }
          }
        }
      },
      "BotPlayRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "position"
        ],
        "properties": {
          "position": {
            "$ref": "#/components/schemas/YENPosition"
          },
          "bot_id": {
            "type": "string",
            "description": "Explicit bot identifier. Takes precedence over strategy."
          },
          "strategy": {
            "type": "string",
            "description": "Optional strategy alias. Supported values: random, biased_random, greedy, minimax."
          }
        },
        "example": {
          "position": {
            "size": 3,
            "turn": 0,
            "players": [
              "B",
              "R"
            ],
            "layout": "./../..."
          },
          "bot_id": "random_bot"
        }
      },
      "BotPlayResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "api_version",
          "bot_id",
          "coords",
          "move"
        ],
        "properties": {
          "api_version": {
            "type": "string"
          },
          "bot_id": {
            "type": "string"
          },
          "coords": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "move": {
            "$ref": "#/components/schemas/YENPosition"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "api"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "api": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/external/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Check the external API status",
        "responses": {
          "200": {
            "description": "API available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/bots": {
      "get": {
        "tags": [
          "Bots"
        ],
        "summary": "List supported public bot identifiers",
        "responses": {
          "200": {
            "description": "Supported bot catalogue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BotCatalogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Register a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialsRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Username already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/login": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Authenticate a user and get a JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get the authenticated user profile and aggregated stats",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/me/history": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get match history for the authenticated user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchHistoryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/games": {
      "post": {
        "tags": [
          "Games"
        ],
        "summary": "Create a new game",
        "description": "If a Bearer token is supplied, the gateway associates the authenticated user to player 0 before delegating to GameY.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Game created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameStateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/games/{gameId}": {
      "get": {
        "tags": [
          "Games"
        ],
        "summary": "Get the current state of a game",
        "parameters": [
          {
            "in": "path",
            "name": "gameId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current game state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameStateResponse"
                }
              }
            }
          },
          "404": {
            "description": "Game not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/games/{gameId}/moves": {
      "post": {
        "tags": [
          "Games"
        ],
        "summary": "Play a move in an existing game",
        "parameters": [
          {
            "in": "path",
            "name": "gameId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated game state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameStateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Move rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/games/{gameId}/resign": {
      "post": {
        "tags": [
          "Games"
        ],
        "summary": "Resign an existing game",
        "parameters": [
          {
            "in": "path",
            "name": "gameId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated game state after resign",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameStateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/play": {
      "post": {
        "tags": [
          "Bots"
        ],
        "summary": "Ask a bot for the next move from a YEN position",
        "description": "This is the tournament-friendly endpoint. It accepts the current board position in YEN, chooses a move with the requested bot and returns both the chosen coordinates and the resulting position in YEN after applying that move.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BotPlayRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chosen move and updated position",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BotPlayResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid position or invalid play request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
