{
  "openapi": "3.1.0",
  "info": {
    "title": "Yovi External Bot API",
    "version": "1.0.0",
    "description": "Public API exposed by the gateway for external clients and tournament bots. It centralizes user access, game management and bot-vs-position move selection without exposing internal service topology."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Operational endpoints."
    },
    {
      "name": "Bots",
      "description": "Bot catalogue and move selection."
    },
    {
      "name": "Users",
      "description": "External user-facing operations exposed through the gateway."
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Coordinates": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "z"
        ],
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "z": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "YENPosition": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "size",
          "turn",
          "players",
          "layout"
        ],
        "properties": {
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Board size."
          },
          "turn": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "Turn encoded in YEN. The engine derives the effective turn from the board layout if needed."
          },
          "players": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string",
              "enum": [
                "B",
                "R"
              ]
            },
            "description": "YEN player symbols. This API expects the standard GameY encoding ['B', 'R']."
          },
          "layout": {
            "type": "string",
            "description": "Board encoded row by row with '/' separators and '.' for empty cells."
          }
        },
        "example": {
          "size": 3,
          "turn": 0,
          "players": [
            "B",
            "R"
          ],
          "layout": "./../..."
        }
      },
      "CredentialsRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "username",
          "token",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "PlayerStats": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "userId",
          "totalGames",
          "victories",
          "defeats",
          "updatedAt"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "totalGames": {
            "type": "integer",
            "minimum": 0
          },
          "victories": {
            "type": "integer",
            "minimum": 0
          },
          "defeats": {
            "type": "integer",
            "minimum": 0
          },
          "updatedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "username",
          "stats"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "stats": {
            "$ref": "#/components/schemas/PlayerStats"
          }
        }
      },
      "MatchHistoryItem": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "gameId",
          "userId",
          "result",
          "endedAt"
        ],
        "properties": {
          "gameId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "win",
              "loss"
            ]
          },
          "endedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MatchHistoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "userId",
          "count",
          "items"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchHistoryItem"
            }
          }
        }
      },
      "BotDescriptor": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bot_id",
          "strategy",
          "description"
        ],
        "properties": {
          "bot_id": {
            "type": "string"
          },
          "strategy": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "BotCatalogResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "default_bot_id",
          "items"
        ],
        "properties": {
          "default_bot_id": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BotDescriptor"
            }
          }
        }
      },
      "BotPlayRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "position"
        ],
        "properties": {
          "position": {
            "type": "string",
            "description": "JSON-encoded YEN position. Example: {\"size\":3,\"turn\":0,\"players\":[\"B\",\"R\"],\"layout\":\"./../...\"}"
          },
          "bot_id": {
            "type": "string",
            "description": "Optional bot identifier. Defaults to random_bot when omitted."
          }
        },
        "example": {
          "position": "{\"size\":3,\"turn\":0,\"players\":[\"B\",\"R\"],\"layout\":\"./../...\"}",
          "bot_id": "random_bot"
        }
      },
      "BotPlayResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "coords"
        ],
        "properties": {
          "coords": {
            "$ref": "#/components/schemas/Coordinates"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "api"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "api": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/external/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Check the external API status",
        "responses": {
          "200": {
            "description": "API available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/bots": {
      "get": {
        "tags": [
          "Bots"
        ],
        "summary": "List supported public bot identifiers",
        "responses": {
          "200": {
            "description": "Supported bot catalogue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BotCatalogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Register a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialsRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Username already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/login": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Authenticate a user and get a JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get the authenticated user profile and aggregated stats",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/users/me/history": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get match history for the authenticated user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchHistoryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/external/v1/play": {
      "get": {
        "tags": [
          "Bots"
        ],
        "summary": "Ask a bot for the next move from a YEN position",
        "description": "Tournament endpoint. It accepts the current board position as a JSON-encoded YEN record in the position query parameter and returns the chosen move coordinates.",
        "parameters": [
          {
            "in": "query",
            "name": "position",
            "required": true,
            "description": "JSON-encoded YEN position.",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "bot_id",
            "required": false,
            "description": "Optional bot identifier. Defaults to random_bot.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chosen move coordinates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BotPlayResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid position or invalid play request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}